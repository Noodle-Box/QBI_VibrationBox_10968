# ==========================================
# 1. PlatformIO & Embedded Firmware
# ==========================================
# Local build environments, compiled binaries, and internal package caches
**/Arduino Files/.pio/
**/Arduino Files/.pioenvs/
**/Arduino Files/.piolibdeps/

# PlatformIO native test artifacts
**/.test/

# ==========================================
# 2. Python
# ==========================================
# Byte-compiled / optimized / dll files
__pycache__/
*.py[cod]
*$py.class

# Local virtual environments
.venv/
venv/
ENV/
env/

# Generated microphone recordings
Python Files/recordings/
Python Files/recordings/**/*.wav
*.wav

# Local hardware settings generated by the Python drivers
Python Files/*_settings.json

# Distribution / packaging profiles
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# 3. Advisor Reference Files
# ==========================================
# Dylan's reference implementation and environment — not part of the project source
Dylan Files/

# ==========================================
# 4. VS Code Workspaces & OS Files
# ==========================================
# Ignore local workspace states, but DO NOT ignore your 'project.code-workspace' file
.vscode/.projects
.vscode/launch.json
.vscode/tasks.json
.vscode/settings.json

# System specific files
.DS_Store
Thumbs.db
